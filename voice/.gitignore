# Audio files are large and can be regenerated from scenes/ via extract scripts
chunks/
raw/
by_speaker/
# by_character/ is also large; the per-chunk files are regenerable
# but the combined .wav files are the actual deliverables for ElevenLabs.
# Track the manifests/summaries but not the audio.
by_character/*/chunks/
by_character/*/*_combined.wav
by_character/*/*_clean_combined.wav
# ElevenLabs TTS candidate samples are regenerable
by_character/*/elevenlabs_candidates/
# Generated dialogue audio is regenerable from the dialogue_data.json
dialogue/
voice_clone_test/
